<!DOCTYPE html>
<html lang="ca">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Civilizations - Civilització</title>
        <link rel="stylesheet" href="estils.css">
    </head>
    <body>

        <header>
            <nav class="navbar">
                <div class="logo">
                    <img src="img/Logo_Civilizations.png" alt="logo">
                    <h1>Civilizations</h1>
                </div>

                <ul class="menu">
                    <li><a href="principal.hbs">Principal</a></li>
                    <li><a href="batalles.hbs">Batalles</a></li>
                    <li><a href="informes.hbs">Informes</a></li>
                    <li><a href="civilitzacio.hbs">Civilització</a></li>
                    <li><a href="programadors.hbs">Programadors</a></li>
                </ul>
            </nav>
        </header>
   
        <main>
            
            <section style="text-align: center;">
                <h2>Recursos de la Civilització</h2>
                <p style="margin-bottom: 5px; color: #111;">Dades actuals de la civilització</p>
                <p style="font-size: 0.85rem; color: #333; margin-bottom: 30px;">Última actualització: 22/05/2026 16:00</p>

                <h3 style="text-align: left; max-width: 900px; margin: 20px auto; font-size: 1.1rem;">Abans de la batalla</h3>
                <hr style="border: 0; border-top: 1px solid rgba(0,0,0,0.1); max-width: 900px; margin: 0 auto 20px auto;">
                
                <div class="cards">
                    <div class="card">
                        <img src="img/menjar.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Menjar</h3>
                        <p>48,700</p>
                    </div>
                    <div class="card">
                        <img src="img/fusta.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Fusta</h3>
                        <p>45,000</p>
                    </div>
                    <div class="card">
                        <img src="img/ferro.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Ferro</h3>
                        <p>42,900</p>
                    </div>
                    <div class="card">
                        <img src="img/mana.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Manà</h3>
                        <p>15,000</p>
                    </div>
                </div>

                <h3 style="text-align: left; max-width: 900px; margin: 40px auto 20px auto; font-size: 1.1rem;">Després de la batalla</h3>
                <hr style="border: 0; border-top: 1px solid rgba(0,0,0,0.1); max-width: 900px; margin: 0 auto 20px auto;">

                <div class="cards">
                    <div class="card">
                        <img src="img/menjar.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Menjar</h3>
                        <p>22,300</p>
                    </div>
                    <div class="card">
                        <img src="img/fusta.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Fusta</h3>
                        <p>27,500</p>
                    </div>
                    <div class="card">
                        <img src="img/ferro.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Ferro</h3>
                        <p>32,900</p>
                    </div>
                    <div class="card">
                        <img src="img/mana.png" style="width: 50px; margin: 0 auto 10px auto; display: block;">
                        <h3 style="margin-bottom: 5px;">Manà</h3>
                        <p>10,000</p>
                    </div>
                </div>
            </section>

        </main>

        <footer>
            <p>Copyright &copy; 2026 Civilizations - Tots els drets reservats.</p>
        </footer>
    </body>
</html>